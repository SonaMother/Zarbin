{
  "appId": "com.sonamother.zarbin",
  "appName": "زرین · Zarbin",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": true,
    "backgroundColor": "#0c322c"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 500,
      "backgroundColor": "#0c322c",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
